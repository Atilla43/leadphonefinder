# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Telethon (получить на https://my.telegram.org)
TELETHON_API_ID=12345678
TELETHON_API_HASH=abcdef1234567890abcdef1234567890
TELETHON_PHONE=+79001234567
TELETHON_SESSION_NAME=userbot_session

# Шерлок бот (username без @)
SHERLOCK_BOT_USERNAME=sherlock_osint_bot

# ============================================
# Dyxless API (рекомендуется)
# ============================================
# Если настроен API — используется вместо Telegram бота
# Быстрее, надёжнее, без риска бана аккаунта
# Документация: https://dyxless.b-cdn.net/api.html
#
# Лимиты: 100 запросов за 15 минут на IP
# Стоимость: standart — 2₽, telegram — 10₽

# SHERLOCK_API_URL=https://api-dyxless.cfd
# SHERLOCK_API_KEY=your_token_from_bot

# Лимиты
REQUEST_DELAY_SECONDS=3.0
MAX_FILE_SIZE_MB=10
MAX_ROWS=100
PROGRESS_UPDATE_INTERVAL=5

# Whitelist (Telegram user IDs, через запятую)
# Оставить пустым для доступа всем
ALLOWED_USER_IDS=123456789,987654321

# История
HISTORY_RETENTION_DAYS=7

# ============================================
# SCRAPPER v2 (поиск компаний по запросу)
# ============================================

# Максимум результатов с каждого источника
SCRAPPER_MAX_RESULTS=100

# Использовать источники (true/false)
SCRAPPER_USE_TWOGIS=true
SCRAPPER_USE_YANDEX=true

# Headless режим браузера
SCRAPPER_HEADLESS=true

# Задержки между запросами (антибан)
SCRAPPER_DELAY_MIN=1.0
SCRAPPER_DELAY_MAX=3.0

# DaData API токен (для поиска ИНН по названию компании)
# Бесплатно: 10,000 запросов/день
# Получить: https://dadata.ru/api/suggest/party/
DADATA_TOKEN=

# ============================================
# LLM для сложных запросов (опционально)
# ============================================
# Провайдеры: openai, gigachat, yandexgpt
# Используется как fallback если fuzzy matching не справился

# OpenAI (ChatGPT)
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# GigaChat (Сбер) - https://developers.sber.ru/portal/products/gigachat
# LLM_PROVIDER=gigachat
# LLM_API_KEY=your_gigachat_auth_key
# LLM_MODEL=GigaChat

# YandexGPT - https://cloud.yandex.ru/services/yandexgpt
# LLM_PROVIDER=yandexgpt
# LLM_API_KEY=your_api_key
# LLM_MODEL=yandexgpt-lite
# LLM_FOLDER_ID=your_folder_id

# ============================================
# Redis (для персистентности задач)
# ============================================
# Опционально. Если не указан — используется in-memory хранилище
# При перезапуске бота без Redis все активные задачи будут потеряны

# URL подключения к Redis
# REDIS_URL=redis://localhost:6379

# TTL задач в секундах (по умолчанию 1 час)
# TASK_TTL_SECONDS=3600
